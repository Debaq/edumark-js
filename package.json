{
  "name": "edumark-js",
  "version": "0.1.0",
  "description": "Decoder for the Edumark (.edm) educational document format",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "browser": "./dist/index.global.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsup --watch"
  },
  "keywords": [
    "edumark",
    "markdown",
    "education",
    "edm",
    "parser"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "markdown-it": "^14.1.0"
  },
  "peerDependencies": {
    "katex": ">=0.16.0"
  },
  "peerDependenciesMeta": {
    "katex": {
      "optional": true
    }
  }
}
